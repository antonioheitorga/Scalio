rules_version = '2';

// Regras de segurança do Firestore para o SCALIO.
//
// Modelo de ameaça (MVP):
//   - Bloquear acesso de quem não é o app (internet pública, scripts aleatórios).
//   - Garantir que dados gravados tenham o formato esperado.
//
// Limitações conhecidas (a endurecer em HU-16/18):
//   - Qualquer sessão autenticada (anônima ou não) pode ler/escrever em qualquer
//     família ou visita. Ainda não há autorização por agrônomo no servidor, porque
//     o PIN é local e não existe relação entre o UID do Firebase e o agrônomo.
//   - Delete bloqueado — o MVP não tem esse fluxo. HU-21 vai trazer soft delete.

service cloud.firestore {
  match /databases/{database}/documents {

    match /families/{familyId} {
      allow read: if request.auth != null;

      allow create, update: if request.auth != null
        && request.resource.data.id is string
        && request.resource.data.agronomistId is string
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.areaHectares is number
        && request.resource.data.areaHectares > 0
        && request.resource.data.cultures is list
        && request.resource.data.cultures.size() > 0
        && request.resource.data.createdAt is string;

      allow delete: if false;
    }

    match /visits/{visitId} {
      allow read: if request.auth != null;

      // Campos opcionais sao validados apenas quando presentes — visitas
      // antigas sem esses campos continuam sendo aceitas.
      allow create, update: if request.auth != null
        && request.resource.data.id is string
        && request.resource.data.familyId is string
        && request.resource.data.agronomistId is string
        && request.resource.data.date is string
        && request.resource.data.type in ['Producao', 'Venda', 'Insumo', 'Problema', 'OrientacaoTecnica']
        && request.resource.data.culture is string
        && request.resource.data.notes is string
        && (!('problemResolved' in request.resource.data) || request.resource.data.problemResolved is bool)
        && (!('problemResolvedAt' in request.resource.data) || request.resource.data.problemResolvedAt is string)
        && (!('problemResolutionNotes' in request.resource.data) || request.resource.data.problemResolutionNotes is string);

      allow delete: if false;
    }

    // Qualquer outra coleção é negada por padrão
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
